# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
JWT_SECRET=verander_dit_naar_iets_geheims_en_langs

# Database. Let op: de bestandsnaam is historisch (seasonfits.db) — bewust niet
# hernoemd omdat bestaande installaties anders hun data kwijtraken.
# Productie (Railway-volume): file:/data/fightmarketing.db
DATABASE_URL=file:./seasonfits.db

# Map voor geüploade afbeeldingen. Productie (Railway-volume): /data/uploads
UPLOADS_DIR=

# Eerste admin-account op een verse database (alleen gebruikt als er nog
# geen admin bestaat — daarna kun je deze weghalen)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── URLs ──────────────────────────────────────────────────────────────────────
# Publieke site-URL. Productie: https://fightmarketing.nl
# Gebruikt voor Mollie-redirects en links in e-mails.
APP_URL=http://localhost:5174

# Publieke API-URL voor Mollie-webhooks zodra de site live staat
# (Mollie weigert localhost). Productie bijv.: https://api.fightmarketing.nl
BASE_URL=

# ── E-mail (optioneel) ────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@fightmarketing.nl

# ── Mollie (leeg = mock-modus met gesimuleerde betaalpagina) ──────────────────
MOLLIE_API_KEY=
